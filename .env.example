# Copiar a .env y completar con valores reales. NUNCA commitear .env.

# PostgreSQL — Supabase: Project Settings → Database → Connection string → URI
# Usar la URI con "Session mode" (puerto 5432), NO Transaction mode
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# Clave para firmar cookies de sesión — generar con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Supabase — Project Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_KEY=eyJ...  # anon/public key

# URL pública de la app (sin trailing slash)
# Local: http://localhost:8000
# Producción: https://finanzas.onrender.com
APP_URL=http://localhost:8000
